---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Diana Minji Chun">
  <div class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-semibold tracking-tight mb-12">About</h1>

    <div class="grid grid-cols-1 tablet:grid-cols-3 gap-12">
      <!-- Photo -->
      <div class="tablet:col-span-1">
        <div class="aspect-square rounded-xl bg-gray-100 overflow-hidden">
          <img src="/images/diana-chun.jpg" alt="Diana Minji Chun" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Bio -->
      <div class="tablet:col-span-2 space-y-5 text-gray-600 leading-relaxed">
        <p>
          Designer who cares about the whole system, not just the screen. I've spent 8 years designing at scale—privacy experiences for 680M Microsoft users, events for the White House and National Geographic, and growth funnels that actually respect people. I'm drawn to messy, complex problems where design meets policy, equity, and real stakes. 
        </p>
        <p>
          When I'm not designing, I'm spending time playing board games, swimming laps, and going on long walks with my partner, two kids, and a chihuahua.
        </p>

        <div class="pt-4 flex flex-wrap gap-4 text-sm">
          <a href="mailto:diana.chun@outlook.com" class="font-medium text-gray-900 hover:text-gray-500 transition-colors">
            Email →
          </a>
          <a href="https://www.linkedin.com/in/diana-chun-design/" target="_blank" rel="noopener" class="font-medium text-gray-900 hover:text-gray-500 transition-colors">
            LinkedIn →
          </a>
          <a href="/Diana Minji Chun Resume 2026.pdf" target="_blank" class="font-medium text-gray-900 hover:text-gray-500 transition-colors">
            Resume →
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
