  <VimeoEmbed id="1172790255" />

  <script>
    const MOBILE_BREAKPOINT = 810;

    function initAnnotations() {
      const isMobile = window.innerWidth < MOBILE_BREAKPOINT;

      document.querySelectorAll('details.annotation').forEach(details => {
        const summary = details.querySelector('summary');
        const content = details.querySelector('.accordion-content');
        const chevron = details.querySelector('.chevron');

        // Remove any previously attached listener
        summary.onclick = null;

        if (isMobile) {
          chevron.classList.remove('hidden');
          details.removeAttribute('open');
          content.style.maxHeight = '0';
          content.style.opacity = '0';
          content.style.transition = 'max-height 0.5s ease, opacity 0.5s ease';
          details.style.cursor = 'pointer';

          summary.onclick = e => {
            e.preventDefault();
            if (details.open) {
              content.style.maxHeight = '0';
              content.style.opacity = '0';
              chevron.style.transform = 'rotate(0deg)';
              setTimeout(() => details.removeAttribute('open'), 500);
            } else {
              details.setAttribute('open', '');
              content.style.maxHeight = content.scrollHeight + 'px';
              content.style.opacity = '1';
              chevron.style.transform = 'rotate(180deg)';
            }
          };
        } else {
          chevron.classList.add('hidden');
          details.setAttribute('open', '');
          content.style.maxHeight = '';
          content.style.opacity = '';
          content.style.transition = '';
          details.style.cursor = '';
        }
      });
    }

    initAnnotations();
    window.addEventListener('resize', initAnnotations);
  </script>

  <h2>Outcome</h2>
  <div class="not-prose mt-6">
    <div class="space-y-8 text-sm text-gray-700">
      <!-- Item 1: Green star -->
      <div>
        <p class="font-semibold text-gray-900 mb-2">
          <svg style="display: inline; width: 1em; height: 1em; vertical-align: -0.15em;" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.5674 13.5674C13.5603 13.6091 12.4059 20.3506 10.1748 20.3506C7.94439 20.3497 6.7907 13.6113 6.7832 13.5674C6.73312 13.5588 0.000849867 12.4052 0 10.1758C2.92427e-07 7.9458 6.73505 6.79142 6.7832 6.7832C6.79212 6.73096 7.94648 0 10.1758 0C12.4045 0.000824531 13.5581 6.72881 13.5674 6.7832C13.6138 6.79113 20.3506 7.94551 20.3506 10.1758C20.3498 12.4054 13.6164 13.559 13.5674 13.5674Z" fill="#92C159"/></svg> Shipped first motion across the current WXP.
        </p>
        <p class="leading-relaxed">This work introduced the first instance of motion across the current Word,Excel, and PowerPoint. Motion was used intentionally—not as decoration, but as a way to provide immediate feedback, communicate progress, and set an emotional tone aligned with productivity. We learned the power of motion as a relationship-building tool, helping users feel oriented, acknowledged, and guided through setup.</p>
      </div>
      <!-- Item 2: Blue star -->
      <div>
