export const projectMeta = {
  title: "Fix a broken onboarding to address 97% churn",
  image: "/images/Thumbnails/Project 1.png",
  description: "Turning fragmented setup into a progress-driven experience for 30M freemium users",
  tags: ["Design strategy", "B2C", "Freemium upsell"],
  date: "May–July 2025",
  locked: true,
  href: "/work/project-2",
};

import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import VimeoEmbed from '../../components/VimeoEmbed.astro';
import ImageGallery from '../../components/ImageGallery.astro';
---


<CaseStudyLayout
  title="Fix a broken onboarding to address 97% churn"
  description="Turning fragmented setup into a progress-driven experience for 30M freemium users"
  role="Lead product designer"
  timeline="May–July 2025"
  toolsLabel="Collaboration"
  tools="PM, Engineering, Content, Research, Data science, Business, Design system team"
  tags={["Design strategy", "B2C", "Freemium upsell"]}
>
  <h2>Overview</h2>
  <div class="not-prose grid grid-cols-1 gap-6 mt-6">
    <div>
      <p class="text-xs font-normal uppercase tracking-widest text-gray-400 mb-2">Problem</p>
      <p class="text-sm text-gray-500 leading-relaxed">97% of 30M monthly freemium users churned before completing setup — not because the product failed them, but because onboarding did. Fragmented flows, pop-up overload, and no clear hierarchy caused 43% to drop off by their second session.</p>
    </div>
    <div>
      <p class="text-xs font-normal uppercase tracking-widest text-gray-400 mb-2">Solution</p>
      <p class="text-sm text-gray-500 leading-relaxed">Consolidated scattered setup tasks into a single, progress-driven flow using the Zeigarnik Effect to create forward momentum. Paired with a restrained visual tone and intentional motion, the experience guided users through setup without overwhelming them.</p>
    </div>
    <div>
      <p class="text-xs font-normal uppercase tracking-widest text-gray-400 mb-2">Impact</p>
      <p class="text-sm text-gray-500 leading-relaxed">Click-through rates for setup tasks outperformed default ad content. Word saw a lift in Day 0 Core Actions. The work also introduced the first instance of motion across Word, Excel, and PowerPoint — used not as decoration, but as a tool for feedback, orientation, and trust-building.</p>
    </div>
  </div>

