---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Diana Minji Chun">
  <div class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-semibold tracking-tight mb-4">Get in touch</h1>
    <p class="text-xl text-gray-500 mb-12 leading-relaxed">
      Open to full-time roles, contract work, and interesting conversations.
    </p>

    <div class="space-y-4 text-lg">
      <a
        href="mailto:you@example.com"
        class="flex items-center gap-3 text-gray-900 hover:text-gray-500 transition-colors"
      >
        <span class="text-gray-300">→</span>
        you@example.com
      </a>
      <a
        href="https://linkedin.com/in/yourname"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-3 text-gray-900 hover:text-gray-500 transition-colors"
      >
        <span class="text-gray-300">→</span>
        LinkedIn
      </a>
    </div>
  </div>
</BaseLayout>
