---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import LandingAnimation from '../components/LandingAnimation.astro';

const projectModules = await Astro.glob('./work/project-*.astro');
const projects = projectModules
  .map(mod => mod.projectMeta)
  .filter(Boolean)
  .sort((a, b) => a.href.localeCompare(b.href));
---

<BaseLayout title="Diana Minji Chun — Product Designer">
  <LandingAnimation />
  <div class="max-w-5xl mx-auto px-6 desktop:flex desktop:items-start">

    <!-- Hero -->
    <section class="py-24 desktop:flex-1 desktop:pr-16">
      <div class="flex items-start gap-4 max-w-xl">
        <div class="shrink-0 rounded-xl overflow-hidden" style="width:3.5rem;height:3.5rem;">
          <img src="/icons/Diana Icon.png" alt="Diana Minji Chun" class="w-full h-full object-cover" />
        </div>
        <p class="text-base text-gray-500 leading-relaxed">
          Hi. I'm <strong style="color: #032F98;">Diana Minji Chun</strong> — a product designer who's spent my career bridging community-centered design with execution at scale.
        </p>
      </div>
      <div class="mt-4 max-w-xl">
        <p class="text-base text-gray-500 leading-relaxed">
          For my master's thesis at Carnegie Mellon, I co-designed a participatory budgeting process with low-income communities in Pennsylvania. Since then, I've spent five years at Microsoft leading growth design for experiences reaching 800+ million users.
        </p>
        <p class="text-base text-gray-500 leading-relaxed mt-4">I bring together:</p>
        <div class="mt-2 flex flex-col gap-2">
          <p class="text-base text-gray-500 flex items-start gap-2">
            <span class="mt-0.5 shrink-0 inline-block" style="transition: transform 1.2s ease;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-red-flower" /></svg></span>
            Systems thinking from designing with communities who taught me that real change requires meeting people where they are
          </p>
          <p class="text-base text-gray-500 flex items-start gap-2">
            <span class="mt-0.5 shrink-0 inline-block" style="transition: transform 1.2s ease;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-blue-12-star" /></svg></span>
            Data fluency from driving measurable engagement improvements through experimentation and user research
          </p>
          <p class="text-base text-gray-500 flex items-start gap-2">
            <span class="mt-0.5 shrink-0 inline-block" style="transition: transform 1.2s ease;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-green-4-star" /></svg></span>
            Visual craft from contributing to cross-platform design systems used across global digital products
          </p>
        </div>
        <p class="text-base text-gray-500 leading-relaxed mt-4">
          I'm looking for work where design strengthens access, builds trust, and creates equity — whether that's large companies with global impact, mission-driven organizations, or a few people solving meaningful problems. Find my work interesting? <a href="mailto:diana.chun@outlook.com" class="underline hover:text-gray-700 transition-colors">Let's connect.</a>
        </p>
      </div>

      <h2 class="text-xs uppercase tracking-widest text-gray-400 mt-12 mb-4">AI use disclaimer</h2>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        This website was vibe-coded from scratch using Claude Code. Claude and Microsoft Copilot helped me format, rewrite, and check my case studies. However, I was the final approver and director of everything you see on this portfolio. The content and numbers are accurate to my knowledge.
      </p>
    </section>

    <!-- Work -->
    <section id="work" class="pb-24 desktop:w-[370px] desktop:shrink-0 desktop:sticky desktop:top-14 desktop:py-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-8" style="border-top: none; padding-top: 0; margin-top: 0;">
        Selected Work
      </h2>
      <div class="flex flex-col">
        {projects.map(p => (
          <ProjectCard
            title={p.title}
            description={p.description}
            href={p.href}
            tags={p.tags}
            locked={p.locked}
            date={p.date}
            image={p.image}
          />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
