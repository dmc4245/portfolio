---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projectModules = await Astro.glob('./work/project-*.astro');
const projects = projectModules
  .map(mod => mod.projectMeta)
  .filter(Boolean)
  .sort((a, b) => a.href.localeCompare(b.href));
---

<BaseLayout title="Diana Minji Chun — Product Designer">
  <div class="max-w-5xl mx-auto px-6 desktop:flex desktop:items-start">

    <!-- Hero -->
    <section class="py-24 desktop:flex-1 desktop:pr-16">
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        Hi. My name is <strong style="color: #032F98;">Diana Minji Chun</strong> — a designer, facilitator, and synthesizer on the Growth team at Microsoft. I bring together three ingredients to bring design that works for both business and end users:
      </p>
      <div class="mt-4 flex flex-col gap-2 max-w-xl">
        <p class="text-base text-gray-500 flex items-start gap-2">
          <span class="mt-0.5 shrink-0 inline-block" style="transition: transform 1.2s ease;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-blue-12-star" /></svg></span>
          data to understand the problem,
        </p>
        <p class="text-base text-gray-500 flex items-start gap-2">
          <span class="mt-0.5 shrink-0 inline-block" style="transition: transform 1.2s ease;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-green-4-star" /></svg></span>
          visual craft to communicate the solution, and
        </p>
        <p class="text-base text-gray-500 flex items-start gap-2">
          <span class="mt-0.5 shrink-0 inline-block" style="transition: transform 1.2s ease;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-red-flower" /></svg></span>
          empathy to keep real people at the center of it all.
        </p>
      </div>
      <h2 class="text-xs uppercase tracking-widest text-gray-400 mt-12 mb-4">Experience</h2>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        My career has moved across mediums — from building sets for operas and musicals right out of architecture school, to designing event graphics for the US White House, National Geographic, and Politico in D.C., to product design at Microsoft. What's stayed consistent is a focus on moments of user growth and delight.
      </p>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed mt-4">
        Today at <img src="/icons/Microsoft.svg" alt="Microsoft" width="16" height="16" class="inline-block align-middle" /> Microsoft, I lead cross‑functional design efforts to make Microsoft 365 and Copilot easier to adopt at scale, driving engagement and acquisition across the ecosystem.
      </p>

      <h2 class="text-xs uppercase tracking-widest text-gray-400 mt-12 mb-4">Study</h2>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        I studied architecture and fine arts as an undergrad, then went on to earn my Master of Design from <img src="/icons/Tartan.png" alt="CMU" width="18" height="18" class="inline-block align-middle" /> Carnegie Mellon University. My thesis explored <a href="https://kilthub.cmu.edu/articles/thesis/Our_Ideas_Belong_Here_Co-Designing_a_Community_Investment_Fund/14824905/1" target="_blank" rel="noopener" class="underline hover:text-gray-700 transition-colors">co-designing a participatory community grant process</a>.
      </p>
    </section>

    <!-- Work -->
    <section id="work" class="pb-24 desktop:w-[370px] desktop:shrink-0 desktop:sticky desktop:top-14 desktop:py-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-8" style="border-top: none; padding-top: 0; margin-top: 0;">
        Selected Work
      </h2>
      <div class="flex flex-col">
        {projects.map(p => (
          <ProjectCard
            title={p.title}
            description={p.description}
            href={p.href}
            tags={p.tags}
            locked={p.locked}
            date={p.date}
            image={p.image}
          />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
