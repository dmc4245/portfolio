---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projectModules = await Astro.glob('./work/project-*.astro');
const projects = projectModules
  .map(mod => mod.projectMeta)
  .filter(Boolean)
  .sort((a, b) => a.href.localeCompare(b.href));
---

<BaseLayout title="Diana Minji Chun — Product Designer">
  <div class="max-w-5xl mx-auto px-6 desktop:flex desktop:items-start">

    <!-- Hero -->
    <section class="py-24 desktop:flex-1 desktop:pr-16">
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        I'm Diana — a designer, facilitator, and synthesizer on the Growth team at Microsoft. I bring together three ingredients to bring design that works for both business and end users: <span class="inline-block align-middle" style="transition: transform 1.2s ease; display: inline-block;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-blue-12-star" /></svg></span> data to understand the problem, <span class="inline-block align-middle" style="transition: transform 1.2s ease; display: inline-block;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-green-4-star" /></svg></span> visual craft to communicate the solution, and <span class="inline-block align-middle" style="transition: transform 1.2s ease; display: inline-block;" onmouseenter="this.style.transform='rotate(180deg)'" onmouseleave="this.style.transform='rotate(0deg)'"><svg width="18" height="18" aria-hidden="true"><use href="/icons/sprite.svg#icon-red-flower" /></svg></span> empathy to keep real people at the center of it all.
      </p>
      <h2 class="text-xs uppercase tracking-widest text-gray-400 mt-12 mb-4">Experience</h2>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        My career has moved across mediums — from building sets for operas and musicals right out of architecture school, to designing event graphics for the US White House, National Geographic, and Politico in D.C., to product design at Microsoft. What's stayed consistent is a focus on moments of user growth and delight.
      </p>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed mt-4">
        Today at <img src="/icons/Microsoft.svg" alt="Microsoft" width="16" height="16" class="inline-block align-middle" /> Microsoft, I lead cross‑functional design efforts to make Microsoft 365 and Copilot easier to adopt at scale, driving engagement and acquisition across the ecosystem.
      </p>

      <h2 class="text-xs uppercase tracking-widest text-gray-400 mt-12 mb-4">Study</h2>
      <p class="text-base text-gray-500 max-w-xl leading-relaxed">
        I studied architecture and fine arts as an undergrad, then went on to earn my Master of Design from <img src="/icons/Tartan.png" alt="CMU" width="18" height="18" class="inline-block align-middle" /> Carnegie Mellon University. My thesis explored co-designing a participatory community grant process.
      </p>
    </section>

    <!-- Work -->
    <section id="work" class="pb-24 desktop:w-[370px] desktop:shrink-0 desktop:sticky desktop:top-14 desktop:py-24">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-8">
        Selected Work
      </h2>
      <div class="flex flex-col">
        {projects.map(p => (
          <ProjectCard
            title={p.title}
            description={p.description}
            href={p.href}
            tags={p.tags}
            locked={p.locked}
            date={p.date}
            image={p.image}
          />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
