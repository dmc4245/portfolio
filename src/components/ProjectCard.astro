---
interface Props {
  title: string;
  description: string;
  image?: string;
  tags?: string[];
  href: string;
  locked?: boolean;
  date?: string;
}

const { title, description, image, tags = [], href, locked = false, date } = Astro.props;

const meta = [locked ? '🔒' : null, ...tags, date].filter(Boolean).join(' · ');
---

<a
  href={href}
  class="group flex items-center gap-4 py-4 border-b border-gray-100 last:border-b-0"
>
  <!-- Thumbnail -->
  <div class="shrink-0 w-14 h-14 rounded-xl overflow-hidden bg-gray-900 flex items-center justify-center">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover"
      />
    ) : (
      <svg width="24" height="24" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24" opacity="0.4">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <path d="M21 15l-5-5L5 21"/>
      </svg>
    )}
  </div>

  <!-- Info -->
  <div class="min-w-0">
    <h3 class="font-medium text-gray-900 group-hover:text-gray-500 transition-colors leading-snug">
      {title}
    </h3>
    <p class="mt-1 text-sm text-gray-400 truncate" style="font-family: 'IBM Plex Mono', monospace;">{meta}</p>
  </div>
</a>
