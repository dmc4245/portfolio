---
interface Email {
  sender: string;
  subject: string;
  date: string;
  to?: string;
  image: string;
}

interface Props {
  emails: Email[];
}

const { emails } = Astro.props;
const id = `ew-${Math.random().toString(36).slice(2, 8)}`;
---

<div id={id} class="email-window not-prose w-full rounded-2xl overflow-hidden shadow-xl border border-gray-200 bg-[#F3F3F3] font-sans select-none" style="font-family: 'Inter', sans-serif;">

  <!-- Window chrome -->
  <div class="flex items-center gap-2 px-4 h-10 bg-[#EBEBEB] border-b border-gray-200">
    <span class="w-3 h-3 rounded-full bg-gray-300"></span>
    <span class="w-3 h-3 rounded-full bg-gray-300"></span>
    <span class="w-3 h-3 rounded-full bg-gray-300"></span>
    <span class="ml-3 text-xs text-gray-400 font-medium tracking-wide">Inbox</span>
  </div>

  <!-- Body -->
  <div class="flex" style="height: 640px;">

    <!-- Email list -->
    <div class="email-list w-full tablet:w-64 shrink-0 bg-white border-r border-gray-200 overflow-y-auto">
      <div class="px-4 py-2 text-xs font-medium text-gray-400 uppercase tracking-widest border-b border-gray-100">Today</div>
      {emails.map((email, i) => (
        <button
          class="email-list-item w-full text-left flex items-center gap-3 px-4 py-3 border-b border-gray-100 hover:bg-gray-50 transition-colors"
          data-index={i}
          data-target={id}
        >
          <!-- Avatar -->
          <div class="shrink-0 w-8 h-8 rounded-full bg-gray-300"></div>
          <!-- Text -->
          <div class="min-w-0 flex-1">
            <div class="flex items-center justify-between gap-2">
              <span class="text-xs font-semibold text-gray-800 truncate">{email.sender}</span>
              <span class="text-[10px] text-gray-400 shrink-0">{email.date}</span>
            </div>
            <p class="text-xs text-gray-400 truncate mt-0.5">{email.subject}</p>
          </div>
        </button>
      ))}
    </div>

    <!-- Preview panel -->
    <div class="email-preview flex flex-col flex-1 min-w-0 bg-white overflow-hidden">

      <!-- Mobile back button (only shows on mobile) -->
      <button class="email-back tablet:hidden flex items-center gap-1 px-4 py-2 text-xs text-gray-500 border-b border-gray-100 hover:text-gray-900 transition-colors">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back
      </button>

      <!-- Email header -->
      <div class="shrink-0 px-6 py-4 border-b border-gray-100">
        <p class="email-preview-subject text-sm font-semibold text-gray-900 mb-3 truncate"></p>
        <div class="flex items-center gap-3">
          <div class="shrink-0 w-8 h-8 rounded-full bg-gray-300"></div>
          <div class="min-w-0">
            <p class="email-preview-sender text-xs font-semibold text-gray-800"></p>
            <p class="email-preview-meta text-[10px] text-gray-400 mt-0.5"></p>
          </div>
          <p class="email-preview-date ml-auto text-[10px] text-gray-400 shrink-0"></p>
        </div>
      </div>

      <!-- Email image (scrollable) -->
      <div class="flex-1 overflow-y-auto bg-white px-16 pb-8">
        <img class="email-preview-image block h-auto" src="" alt="" style="width: 800px; max-width: 100%;" />
      </div>

    </div>


  </div>
</div>

<!-- Store email data for JS -->
<script type="application/json" id={`${id}-data`} set:html={JSON.stringify(emails)} />

<script>
  document.querySelectorAll<HTMLElement>('.email-window').forEach((win) => {
    if (win.dataset.init) return;
    win.dataset.init = '1';

    const id = win.id;
    const dataEl = document.getElementById(`${id}-data`);
    if (!dataEl) return;
    const emails: { sender: string; subject: string; date: string; to?: string; image: string }[] = JSON.parse(dataEl.textContent ?? '[]');

    const list = win.querySelector<HTMLElement>('.email-list')!;
    const preview = win.querySelector<HTMLElement>('.email-preview')!;
    const backBtn = win.querySelector<HTMLElement>('.email-back')!;

    const subjectEl = preview.querySelector<HTMLElement>('.email-preview-subject')!;
    const senderEl = preview.querySelector<HTMLElement>('.email-preview-sender')!;
    const metaEl = preview.querySelector<HTMLElement>('.email-preview-meta')!;
    const dateEl = preview.querySelector<HTMLElement>('.email-preview-date')!;
    const imgEl = preview.querySelector<HTMLImageElement>('.email-preview-image')!;

    let activeItem: HTMLElement | null = null;

    function openEmail(index: number) {
      const email = emails[index];
      if (!email) return;

      subjectEl.textContent = email.subject;
      senderEl.textContent = email.sender;
      metaEl.textContent = email.to ? `To: ${email.to}` : '';
      dateEl.textContent = email.date;
      imgEl.src = email.image;
      imgEl.alt = email.subject;

      // Scroll image back to top
      imgEl.closest('.overflow-y-auto')?.scrollTo(0, 0);

      // Active highlight
      if (activeItem) activeItem.classList.remove('bg-blue-50');
      activeItem = win.querySelector<HTMLElement>(`[data-index="${index}"]`);
      if (activeItem) activeItem.classList.add('bg-blue-50');

      // Mobile: hide list, show preview
      if (window.innerWidth < 810) {
        list.classList.add('hidden');
      }
    }

    win.querySelectorAll<HTMLElement>('.email-list-item').forEach((item) => {
      item.addEventListener('click', () => openEmail(parseInt(item.dataset.index ?? '0')));
    });

    backBtn.addEventListener('click', () => {
      list.classList.remove('hidden');
      if (activeItem) activeItem.classList.remove('bg-blue-50');
      activeItem = null;
    });

    // Open first email by default on desktop
    if (window.innerWidth >= 810 && emails.length > 0) {
      openEmail(0);
    }
  });
</script>
